{
  "name": "hire-flow-ncpa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NCPA Venue for Hire — internal operations application (Cloudflare Pages + Workers + D1 + R2)",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev dist --local --persist-to .wrangler/state --port 8788",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply ncpa-hire-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ncpa-hire-db --remote",
    "db:seed:local": "tsx scripts/seed/run-seed.ts --env local",
    "db:seed:preview": "tsx scripts/seed/run-seed.ts --env preview",
    "db:demo:local": "tsx scripts/seed/demo-events.ts --env=local",
    "db:demo:remote": "tsx scripts/seed/demo-events.ts --env=remote --allow-remote-demo",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts",
    "schema:xlsx": "tsx scripts/generate-event-form-schema-xlsx.ts",
    "deploy": "npm run build && wrangler pages deploy dist --project-name ncpa-hire",
    "deploy:scheduler": "wrangler deploy --config scheduler/wrangler.jsonc"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@hookform/resolvers": "^3.9.0",
    "@noble/hashes": "^1.5.0",
    "@tanstack/react-query": "^5.51.0",
    "clsx": "^2.1.1",
    "hono": "^4.6.0",
    "otpauth": "^9.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-router-dom": "^6.26.0",
    "resend": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.8.0",
    "globals": "^17.7.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.98.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  }
}
